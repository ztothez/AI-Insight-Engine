# AI Insight Engine environment template
# Copy this file to .env for local development:
# cp .env.example .env

# LLM + embeddings provider
TOGETHER_API_KEY=replace_with_your_together_api_key

# PostgreSQL / pgvector
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT_CONTAINER=5432
DB_NAME=ai_insight_engine

# Redis cache
REDIS_URL=redis://localhost:6379/0

# SQLAlchemy logging
SQLALCHEMY_ECHO=false
